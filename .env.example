# No Railway, DATABASE_URL é provida automaticamente pelo plugin PostgreSQL
DATABASE_URL=postgresql+psycopg2://usuario:senha@host:5432/nome_do_banco

APP_NAME=Sports Analysis Bot v3
DEBUG=False

# Telegram Bot
TELEGRAM_TOKEN=seu_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# JWT Auth
SECRET_KEY=gere_uma_chave_secreta_forte_com_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Bzzoiro Sports Data API
BSD_API_KEY=sua_api_key_aqui
